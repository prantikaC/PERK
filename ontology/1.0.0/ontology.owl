<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/perkonto#"
     xml:base="https://w3id.org/perkonto"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/perkonto">
        <owl:versionIRI rdf:resource="https://w3id.org/perkonto/1.0.0"/>
        <terms:creator>Debarshi Kumar Sanyal</terms:creator>
        <terms:creator>Partha Pratim Das</terms:creator>
        <terms:creator>Prantika Chakraborty</terms:creator>
        <terms:creator>Srijoni Majumdar</terms:creator>
        <terms:description xml:lang="en">A domain-specific ontology for representing the professional  knowledge of a researcher as extractable from personal email  communications. PERKOnto models communication infrastructure, researchers and venues, the publication lifecycle, and research content,  anchoring every assertion to its provenance email.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">PERKOnto: Personal Email Research Knowledge Ontology</terms:title>
        <rdfs:seeAlso rdf:resource="https://github.com/prantikaC/PERK"/>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#gYear -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#gYear"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#time -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#time"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/isPartOf -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/isPartOf"/>
    


    <!-- http://purl.org/dc/terms/references -->


    <owl:ObjectProperty rdf:about="http://purl.org/dc/terms/references"/>
    


    <!-- http://purl.org/ontology/bibo/authorList -->


    <owl:ObjectProperty rdf:about="http://purl.org/ontology/bibo/authorList"/>
    


    <!-- http://www.w3.org/ns/prov#wasInformedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasInformedBy"/>
    


    <!-- https://schema.org/attendee -->


    <owl:ObjectProperty rdf:about="https://schema.org/attendee"/>
    


    <!-- https://schema.org/author -->


    <owl:ObjectProperty rdf:about="https://schema.org/author"/>
    


    <!-- https://schema.org/isRelatedTo -->


    <owl:ObjectProperty rdf:about="https://schema.org/isRelatedTo"/>
    


    <!-- https://schema.org/knowsAbout -->


    <owl:ObjectProperty rdf:about="https://schema.org/knowsAbout"/>
    


    <!-- https://schema.org/recipient -->


    <owl:ObjectProperty rdf:about="https://schema.org/recipient"/>
    


    <!-- https://schema.org/sender -->


    <owl:ObjectProperty rdf:about="https://schema.org/sender"/>
    


    <!-- https://schema.org/subjectOf -->


    <owl:ObjectProperty rdf:about="https://schema.org/subjectOf"/>
    


    <!-- https://w3id.org/perkonto#attends -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#attends">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/attendee"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Conference"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Meeting"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a Person to a Meeting or Conference they attend.</rdfs:comment>
        <rdfs:label xml:lang="en">attends</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#evaluates -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#evaluates">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/isRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Metric"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Dataset"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Method"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Task"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a Metric to the Task, Method, or Dataset it  evaluates.</rdfs:comment>
        <rdfs:label xml:lang="en">evaluates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#hasAuthor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#hasAuthor">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/ontology/bibo/authorList"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Paper"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:comment xml:lang="en">Links a Paper to one of its author Persons.</rdfs:comment>
        <rdfs:label xml:lang="en">has author</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#hasPaperInfo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#hasPaperInfo">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/subjectOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Paper"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#PaperBib"/>
        <rdfs:comment xml:lang="en">Links a Paper to its bibliographic record.</rdfs:comment>
        <rdfs:label xml:lang="en">has paper info</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#identifies -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#identifies">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/references"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#SubmissionID"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Paper"/>
        <rdfs:comment xml:lang="en">Links a SubmissionID to the Paper it identifies.</rdfs:comment>
        <rdfs:label xml:lang="en">identifies</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#inVenue -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#inVenue">
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#SubmissionID"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Conference"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Journal"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a SubmissionID to its target Conference or Journal.</rdfs:comment>
        <rdfs:label xml:lang="en">in venue</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#movesTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#movesTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasInformedBy"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#PaperStatus"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#SubmissionID"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#PaperStatus"/>
        <rdfs:comment xml:lang="en">Links a SubmissionID to its initial PaperStatus, or one  PaperStatus to the next, encoding the submission lifecycle as a directed  state machine.</rdfs:comment>
        <rdfs:label xml:lang="en">moves to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#partOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#partOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/isPartOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Email"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#MailThread"/>
        <rdfs:comment xml:lang="en">Links an Email to the MailThread it belongs to.</rdfs:comment>
        <rdfs:label xml:lang="en">part of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#receivedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#receivedBy">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/recipient"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Email"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:comment xml:lang="en">Links an Email to the Person(s) who received it.</rdfs:comment>
        <rdfs:label xml:lang="en">received by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#sentBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#sentBy">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/sender"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Email"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:comment xml:lang="en">Links an Email to the Person who sent it.</rdfs:comment>
        <rdfs:label xml:lang="en">sent by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#usedFor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#usedFor">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/isRelatedTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Dataset"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Method"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Task"/>
        <rdfs:comment xml:lang="en">Links a Dataset or Method to the Task it is applied to.</rdfs:comment>
        <rdfs:label xml:lang="en">used for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#uses -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#uses">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/isRelatedTo"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Method"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Dataset"/>
        <rdfs:comment xml:lang="en">Links a Method to a Dataset it is trained or evaluated  on.</rdfs:comment>
        <rdfs:label xml:lang="en">uses</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#worksOn -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#worksOn">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/knowsAbout"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:range rdf:resource="https://w3id.org/perkonto#Task"/>
        <rdfs:comment xml:lang="en">Links a Person to a Task they are working on.</rdfs:comment>
        <rdfs:label xml:lang="en">works on</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/perkonto#worksWith -->


    <owl:ObjectProperty rdf:about="https://w3id.org/perkonto#worksWith">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/knowsAbout"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Dataset"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Method"/>
                    <rdf:Description rdf:about="https://w3id.org/perkonto#Metric"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Links a Person to a Method, Dataset, or Metric they use  in their research.</rdfs:comment>
        <rdfs:label xml:lang="en">works with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/ontology/bibo/doi -->


    <owl:DatatypeProperty rdf:about="http://purl.org/ontology/bibo/doi"/>
    


    <!-- http://purl.org/ontology/bibo/issue -->


    <owl:DatatypeProperty rdf:about="http://purl.org/ontology/bibo/issue"/>
    


    <!-- http://purl.org/ontology/bibo/pages -->


    <owl:DatatypeProperty rdf:about="http://purl.org/ontology/bibo/pages"/>
    


    <!-- http://purl.org/ontology/bibo/volume -->


    <owl:DatatypeProperty rdf:about="http://purl.org/ontology/bibo/volume"/>
    


    <!-- http://www.w3.org/ns/prov#generatedAtTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/prov#generatedAtTime"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:DatatypeProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- https://schema.org/affiliation -->


    <owl:DatatypeProperty rdf:about="https://schema.org/affiliation"/>
    


    <!-- https://schema.org/dateCreated -->


    <owl:DatatypeProperty rdf:about="https://schema.org/dateCreated"/>
    


    <!-- https://schema.org/datePublished -->


    <owl:DatatypeProperty rdf:about="https://schema.org/datePublished"/>
    


    <!-- https://schema.org/description -->


    <owl:DatatypeProperty rdf:about="https://schema.org/description"/>
    


    <!-- https://schema.org/location -->


    <owl:DatatypeProperty rdf:about="https://schema.org/location"/>
    


    <!-- https://schema.org/name -->


    <owl:DatatypeProperty rdf:about="https://schema.org/name"/>
    


    <!-- https://schema.org/startDate -->


    <owl:DatatypeProperty rdf:about="https://schema.org/startDate"/>
    


    <!-- https://schema.org/url -->


    <owl:DatatypeProperty rdf:about="https://schema.org/url"/>
    


    <!-- https://w3id.org/perkonto#affiliation -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#affiliation">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/affiliation"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The institutional affiliation of a Person.</rdfs:comment>
        <rdfs:label xml:lang="en">affiliation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#arxivID -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#arxivID">
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#PaperBib"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">arXiv ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#confDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#confDate">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/startDate"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Conference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">conference date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#confTitle -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#confTitle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#confVenue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#confVenue">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/location"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Conference"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">conference venue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#datasetName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#datasetName">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">dataset name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#date -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#date">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/datePublished"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#PaperBib"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#doi -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#doi">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/ontology/bibo/doi"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#PaperBib"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Digital Object Identifier for a published paper.</rdfs:comment>
        <rdfs:label xml:lang="en">DOI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#identifier -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#identifier">
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#SubmissionID"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#issue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#issue">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/ontology/bibo/issue"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#PaperBib"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">issue</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#journalTitle -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#journalTitle">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#mailDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#mailDate">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/dateCreated"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Email"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">The date on which the Email was sent.</rdfs:comment>
        <rdfs:label xml:lang="en">mail date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#mailNum -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#mailNum">
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Email"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">A unique integer identifier for an Email.</rdfs:comment>
        <rdfs:label xml:lang="en">mail number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#meetAgenda -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#meetAgenda">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Meeting"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">meeting agenda</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#meetDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#meetDate">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/startDate"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Meeting"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">meeting date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#meetLink -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#meetLink">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/url"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Meeting"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">meeting link</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#meetTime -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#meetTime">
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Meeting"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
        <rdfs:label xml:lang="en">meeting time</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#methodName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/perkonto#methodName">
        <rdfs:subPropertyOf rdf:resource="https://schema.org/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/perkonto#Method"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">method name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/perkonto#metricName -->


