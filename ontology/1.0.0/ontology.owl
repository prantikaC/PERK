    <!-- https://w3id.org/perkonto#Conference -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Conference">
        <rdfs:subClassOf rdf:resource="http://purl.org/ontology/bibo/Conference"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Event"/>
        <rdfs:comment xml:lang="en">An academic conference to which a paper has been submitted  or which a researcher attends.</rdfs:comment>
        <rdfs:label xml:lang="en">Conference</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Dataset -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Dataset">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Dataset"/>
        <rdfs:comment xml:lang="en">A dataset used or discussed in the research activities  documented in the email corpus.</rdfs:comment>
        <rdfs:label xml:lang="en">Dataset</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Email -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Email">
        <rdfs:subClassOf rdf:resource="https://schema.org/Message"/>
        <rdfs:comment xml:lang="en">An individual email message exchanged between researchers.  Serves as the provenance anchor for all knowledge triples extracted into  PERK. Every relationship carries a source property referencing one or  more Email instances.</rdfs:comment>
        <rdfs:label xml:lang="en">Email</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Journal -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Journal">
        <rdfs:subClassOf rdf:resource="http://purl.org/ontology/bibo/Journal"/>
        <rdfs:subClassOf rdf:resource="https://schema.org/Periodical"/>
        <rdfs:comment xml:lang="en">An academic journal to which a paper has been submitted  or published.</rdfs:comment>
        <rdfs:label xml:lang="en">Journal</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#MailThread -->


    <owl:Class rdf:about="https://w3id.org/perkonto#MailThread">
        <rdfs:subClassOf rdf:resource="https://schema.org/CreativeWork"/>
        <rdfs:comment xml:lang="en">An ordered chain of email messages sharing a common subject  and thread identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">Mail Thread</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Meeting -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Meeting">
        <rdfs:subClassOf rdf:resource="https://schema.org/Event"/>
        <rdfs:comment xml:lang="en">A scheduled meeting between researchers, including virtual  meetings, with an associated agenda and link.</rdfs:comment>
        <rdfs:label xml:lang="en">Meeting</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Method -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Method">
        <rdfs:subClassOf rdf:resource="https://schema.org/SoftwareApplication"/>
        <rdfs:comment xml:lang="en">A computational or analytical method, model, or algorithm  discussed in the email corpus.</rdfs:comment>
        <rdfs:label xml:lang="en">Method</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Metric -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Metric">
        <rdfs:comment xml:lang="en">An evaluation metric used to assess the performance of a  method on a task or dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Metric</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Paper -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Paper">
        <rdfs:subClassOf rdf:resource="http://purl.org/ontology/bibo/AcademicArticle"/>
        <rdfs:comment xml:lang="en">A research paper authored or co-authored by one or more  Persons in the email corpus.</rdfs:comment>
        <rdfs:label xml:lang="en">Paper</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#PaperBib -->


    <owl:Class rdf:about="https://w3id.org/perkonto#PaperBib">
        <rdfs:subClassOf rdf:resource="https://schema.org/ScholarlyArticle"/>
        <rdfs:comment xml:lang="en">A bibliographic metadata record for a published paper,  capturing identifiers, venue, and publication details.</rdfs:comment>
        <rdfs:label xml:lang="en">Paper Bibliographic Record</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#PaperStatus -->


    <owl:Class rdf:about="https://w3id.org/perkonto#PaperStatus">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">A node representing a single state in the submission  lifecycle of a paper (e.g. Submitted, Under Review, Revision Required,  Accepted, Rejected). Status nodes are chained via movesTo to encode  the full submission history.</rdfs:comment>
        <rdfs:label xml:lang="en">Paper Status</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Person -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Person">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">A researcher or collaborator appearing as sender, recipient,  or named entity in the email corpus.</rdfs:comment>
        <rdfs:label xml:lang="en">Person</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#SubmissionID -->


    <owl:Class rdf:about="https://w3id.org/perkonto#SubmissionID">
        <rdfs:comment xml:lang="en">A composite identifier linking a specific paper to a  specific submission instance at a target venue, enabling tracking of  multiple parallel or sequential submissions.</rdfs:comment>
        <rdfs:label xml:lang="en">Submission ID</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/perkonto#Task -->


    <owl:Class rdf:about="https://w3id.org/perkonto#Task">
        <rdfs:subClassOf rdf:resource="https://schema.org/Action"/>
        <rdfs:comment xml:lang="en">A research task or problem formulation that datasets,  methods, or metrics are applied to.</rdfs:comment>
        <rdfs:label xml:lang="en">Task</rdfs:label>
    </owl:Class>
    


