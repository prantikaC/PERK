    "Paper": {"file": "entities/Paper.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["paperTitle"]},
    "Conference": {"file": "entities/Conference.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["confTitle", "confDate", "confVenue"]},
    "Journal": {"file": "entities/Journal.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["journalTitle"]},
    "SubmissionID": {"file": "entities/SubmissionID.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["identifier"]},
