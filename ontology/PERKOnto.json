    "Method": {"file": "entities/Method.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["methodName"]},
    "Task": {"file": "entities/Task.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["taskName", "taskDate"]},
    "Metric": {"file": "entities/Metric.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["metricName"]},
    "PaperBib": {"file": "entities/PaperBib.csv", "id_col": ":ID", "label_col": ":LABEL", "properties": ["doi", "arxivID", "url", "volume", "issue", "pages", "year", "publisher"]}
  },
  "relationships": {
    "sentBy": {"file": "relations/sentBy.csv", "type": "sentBy", "properties": ["context", "source"], "valid_pairs": [["Email", "Person"]]},
