    "partOf": {"file": "relations/partOf.csv", "type": "partOf", "properties": ["context", "source"], "valid_pairs": [["Email", "MailThread"]]},
    "hasAuthor": {"file": "relations/hasAuthor.csv", "type": "hasAuthor", "properties": ["context", "source"], "valid_pairs": [["Paper", "Person"]]},
    "identifies": {"file": "relations/identifies.csv", "type": "identifies", "properties": ["context", "source"], "valid_pairs": [["SubmissionID", "Paper"]]},
    "inVenue": {"file": "relations/inVenue.csv", "type": "inVenue", "properties": ["context", "source"], "valid_pairs": [["SubmissionID", "Conference"], ["SubmissionID", "Journal"]]},
    "movesTo": {"file": "relations/movesTo.csv", "type": "movesTo", "properties": ["context", "source"], "valid_pairs": [["PaperStatus", "PaperStatus"], ["SubmissionID", "PaperStatus"]]},
    "hasPaperInfo": {"file": "relations/hasPaperInfo.csv", "type": "hasPaperInfo", "properties": ["context", "source"], "valid_pairs": [["Paper", "PaperBib"]]},
    "worksWith": {"file": "relations/worksWith.csv", "type": "worksWith", "properties": ["context", "source"], "valid_pairs": [["Person", "Method"], ["Person", "Dataset"], ["Person", "Metric"]]},
    "worksOn": {"file": "relations/worksOn.csv", "type": "worksOn", "properties": ["context", "source"], "valid_pairs": [["Person", "Task"]]},
    "usedFor": {"file": "relations/usedFor.csv", "type": "usedFor", "properties": ["context", "source"], "valid_pairs": [["Dataset", "Task"], ["Method", "Task"]]},
    "evaluates": {"file": "relations/evaluates.csv", "type": "evaluates", "properties": ["context", "source"], "valid_pairs": [["Metric", "Task"], ["Metric", "Method"], ["Metric", "Dataset"]]},
    "uses": {"file": "relations/uses.csv", "type": "uses", "properties": ["context", "source"], "valid_pairs": [["Method", "Dataset"]]},
    "attends": {"file": "relations/attends.csv", "type": "attends", "properties": ["context", "source"], "valid_pairs": [["Person", "Meeting"], ["Person", "Conference"]]}
