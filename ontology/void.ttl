@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix void:    <http://rdfs.org/ns/void#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix vann:    <http://purl.org/vocab/vann/> .
@prefix vcard:   <http://www.w3.org/2006/vcard/ns#> .
@prefix schema:  <https://schema.org/> .
@prefix perk:    <https://w3id.org/perkonto/resource/> .
@prefix perkonto: <https://w3id.org/perkonto#> .

#################################################################
#  Agents (creators + publisher)
#################################################################

perk:Prantika a foaf:Person ; foaf:name "Prantika Chakraborty" .
perk:Debarshi a foaf:Person ; foaf:name "Debarshi Kumar Sanyal" .
perk:Srijoni  a foaf:Person ; foaf:name "Srijoni Majumdar" .
perk:Partha   a foaf:Person ; foaf:name "Partha Pratim Das" .

perk:IACS a foaf:Organization ;
    foaf:name "Indian Association for the Cultivation of Science" ;
    foaf:homepage <https://www.iacs.res.in/> .

perk:contact a vcard:Kind ;
    vcard:fn "Prantika Chakraborty" ;
    vcard:hasEmail <mailto:prantika.ch@gmail.com> .

#################################################################
#  Catalog (DCAT) — the PERK resource bundle
#################################################################

perk:catalog a dcat:Catalog ;
    dcterms:title "PERK: Personal Email Research Knowledge Graph — Resource Catalog"@en ;
    dcterms:description "Catalog of the resources accompanying PERK: the PERKOnto ontology, the synthetic PATRA email corpus, the PRASHNA-PATRA question-answering benchmark, the extraction gold standard, and the constructed personal research knowledge graph."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rights "Released under the Creative Commons Attribution 4.0 International licence (CC BY 4.0)."@en ;
    dcterms:accessRights <http://publications.europa.eu/resource/authority/access-right/PUBLIC> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:modified "2026-06-15"^^xsd:date ;
    dcterms:language "en" ;
    dcterms:identifier <https://doi.org/10.5281/zenodo.20542115> ;
    dcat:version "1.0.0" ;
    owl:versionInfo "1.0.0" ;
    dcterms:bibliographicCitation "Chakraborty, P., Sanyal, D. K., Majumdar, S., & Das, P. P. (2026). PERK: Personal Email Research Knowledge Graph (v1.0.0) [Data set]. Zenodo. https://doi.org/10.5281/zenodo.20542115"@en ;
    dcat:theme <http://eurovoc.europa.eu/100166> ;          # science / scientific research
    dcterms:subject "knowledge graph", "personal knowledge graph", "scholarly communication",
                    "ontology", "information extraction", "question answering" ;
    dcat:contactPoint perk:contact ;
    foaf:homepage <https://github.com/prantikaC/PERK> ;
    dcat:landingPage <https://github.com/prantikaC/PERK> ;
    dcat:dataset perk:PERKOnto, perk:PATRA, perk:PRASHNA-PATRA,
                 perk:extraction-gold, perk:PERK-KG .

#################################################################
#  1. PERKOnto — the ontology (VoID + DCAT)
#################################################################

perk:PERKOnto a void:Dataset, dcat:Dataset ;
    dcterms:title "PERKOnto: Personal Email Research Knowledge Ontology"@en ;
    dcterms:description "A domain ontology modelling the professional knowledge of an academic researcher as expressed in personal email: communication infrastructure, researchers and venues, the publication lifecycle, and research content, with email-based provenance on every assertion."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:language "en" ;
    dcat:version "1.0.0" ;
    dcat:contactPoint perk:contact ;
    owl:versionInfo "1.0.0" ;
    dcterms:conformsTo <http://www.w3.org/2002/07/owl> ;
    vann:preferredNamespaceUri "https://w3id.org/perkonto#" ;
    vann:preferredNamespacePrefix "perkonto" ;
    void:uriSpace "https://w3id.org/perkonto#" ;
    void:rootResource <https://w3id.org/perkonto> ;
    void:vocabulary <http://xmlns.com/foaf/0.1/>, <http://purl.org/ontology/bibo/>,
                    <http://www.w3.org/ns/prov-o>, <https://schema.org/>,
                    <http://purl.org/dc/terms/> ;
    void:classes 14 ;          # PERKOnto-defined OWL classes
    void:properties 14 ;       # PERKOnto-defined object properties
    dcat:landingPage <https://w3id.org/perkonto> ;
    dcat:distribution perk:PERKOnto-ttl, perk:PERKOnto-rdf, perk:PERKOnto-jsonld .

perk:PERKOnto-ttl a dcat:Distribution ;
    dcterms:title "PERKOnto (Turtle)"@en ;
    dcat:mediaType "text/turtle" ;
    dcterms:format <https://www.iana.org/assignments/media-types/text/turtle> ;
    dcat:downloadURL <https://w3id.org/perkonto/PERKOnto.ttl> ;
    dcat:accessURL <https://w3id.org/perkonto> .

perk:PERKOnto-rdf a dcat:Distribution ;
    dcterms:title "PERKOnto (RDF/XML)"@en ;
    dcat:mediaType "application/rdf+xml" ;
    dcterms:format <https://www.iana.org/assignments/media-types/application/rdf+xml> ;
    dcat:downloadURL <https://w3id.org/perkonto/PERKOnto.rdf> .

perk:PERKOnto-jsonld a dcat:Distribution ;
    dcterms:title "PERKOnto (JSON-LD)"@en ;
    dcat:mediaType "application/ld+json" ;
    dcterms:format <https://www.iana.org/assignments/media-types/application/ld+json> ;
    dcat:downloadURL <https://w3id.org/perkonto/PERKOnto.jsonld> .

#################################################################
#  2. PATRA — synthetic email corpus (DCAT)
#################################################################

perk:PATRA a dcat:Dataset ;
    dcterms:title "PATRA: Synthetic Academic Email Corpus"@en ;
    dcterms:description "A synthetic corpus of 1,007 interconnected academic emails spanning six years of simulated research activity, generated with a large language model and designed for ontology-guided scholarly information extraction. Fully synthetic to avoid privacy risks."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:type <http://purl.org/dc/dcmitype/Text> ;
    dcterms:language "en" ;
    dcat:version "1.0.0" ;
    dcat:contactPoint perk:contact ;
    dcat:keyword "synthetic email", "academic correspondence", "information extraction" ;
    dcat:landingPage <https://github.com/prantikaC/PERK> ;
    dcat:distribution [ a dcat:Distribution ;
        dcterms:title "PATRA.txt"@en ;
        dcat:mediaType "text/plain" ;
        dcterms:format <https://www.iana.org/assignments/media-types/text/plain> ;
        dcat:byteSize "2275026"^^xsd:nonNegativeInteger ;
        dcat:downloadURL <https://raw.githubusercontent.com/prantikaC/PERK/main/datasets/PATRA/PATRA.txt> ] .

#################################################################
#  3. PRASHNA-PATRA — QA benchmark (DCAT)
#################################################################

perk:PRASHNA-PATRA a dcat:Dataset ;
    dcterms:title "PRASHNA-PATRA: Competency-Question QA Benchmark"@en ;
    dcterms:description "A benchmark of competency-question-driven natural-language queries over personal research knowledge graphs, covering single-hop retrieval, multi-hop reasoning, temporal reasoning, provenance-aware querying, and intentionally unanswerable questions. Each query carries a gold answer. The released CSV contains 200 queries."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:type <http://purl.org/dc/dcmitype/Dataset> ;
    dcterms:language "en" ;
    dcat:version "1.0.0" ;
    dcat:contactPoint perk:contact ;
    prov:wasDerivedFrom perk:PATRA ;
    dcterms:conformsTo perk:PERKOnto ;
    dcat:keyword "question answering", "benchmark", "competency questions" ;
    dcat:landingPage <https://github.com/prantikaC/PERK> ;
    dcat:distribution [ a dcat:Distribution ;
        dcterms:title "PRASHNA_PATRA.csv"@en ;
        dcat:mediaType "text/csv" ;
        dcterms:format <https://www.iana.org/assignments/media-types/text/csv> ;
        dcat:byteSize "26076"^^xsd:nonNegativeInteger ;
        dcat:downloadURL <https://raw.githubusercontent.com/prantikaC/PERK/main/datasets/PRASHNA_PATRA/PRASHNA_PATRA.csv> ] .

#################################################################
#  4. Extraction gold standard (DCAT)
#################################################################

perk:extraction-gold a dcat:Dataset ;
    dcterms:title "PERK Extraction Gold Standard"@en ;
    dcterms:description "Human-annotated gold triples (2,372 rows) used to evaluate LLM-based knowledge-graph extraction over PATRA at the triple level."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:language "en" ;
    dcat:version "1.0.0" ;
    dcat:contactPoint perk:contact ;
    dcat:keyword "gold standard", "triple extraction", "evaluation" ;
    prov:wasDerivedFrom perk:PATRA ;
    dcterms:conformsTo perk:PERKOnto ;
    dcat:landingPage <https://github.com/prantikaC/PERK> ;
    dcat:distribution [ a dcat:Distribution ;
        dcterms:title "refined_golden_set_target.csv"@en ;
        dcat:mediaType "text/csv" ;
        dcterms:format <https://www.iana.org/assignments/media-types/text/csv> ;
        dcat:byteSize "6007404"^^xsd:nonNegativeInteger ;
        dcat:downloadURL <https://raw.githubusercontent.com/prantikaC/PERK/main/datasets/extraction_gold/refined_golden_set_target.csv> ] .

#################################################################
#  5. PERK knowledge graph — the constructed KG (VoID)
#################################################################

perk:PERK-KG a void:Dataset, dcat:Dataset ;
    dcterms:title "PERK: Personal Email Research Knowledge Graph"@en ;
    dcterms:description "The personal research knowledge graph constructed from PATRA via LLM-based extraction, entity resolution, and ontology-constrained graph population; deployed as a Neo4j labelled property graph and exportable as RDF conforming to PERKOnto."@en ;
    dcterms:creator perk:Prantika, perk:Debarshi, perk:Srijoni, perk:Partha ;
    dcterms:publisher perk:IACS ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:issued "2026"^^xsd:gYear ;
    dcterms:language "en" ;
    dcat:version "1.0.0" ;
    dcat:contactPoint perk:contact ;
    dcat:keyword "knowledge graph", "Neo4j", "property graph", "RDF" ;
    dcterms:source perk:PATRA ;
    prov:wasDerivedFrom perk:PATRA ;
    dcterms:conformsTo perk:PERKOnto ;
    void:vocabulary <https://w3id.org/perkonto#> ;
    # Released graph statistics (relationship assertions; entity/literal triples additional).
    void:properties 14 ;
    void:entities 7207 ;       # typed nodes across 14 entity classes
    void:triples 23495 ;       # relationship assertions (entity/literal triples additional)
    void:classPartition
        [ void:class perkonto:Task        ; void:entities 3530 ] ,
        [ void:class perkonto:Email       ; void:entities 1006 ] ,
        [ void:class perkonto:MailThread  ; void:entities  876 ] ,
        [ void:class perkonto:Meeting     ; void:entities  492 ] ,
        [ void:class perkonto:Method      ; void:entities  443 ] ,
        [ void:class perkonto:Dataset     ; void:entities  309 ] ,
        [ void:class perkonto:Paper       ; void:entities  174 ] ,
        [ void:class perkonto:Metric      ; void:entities  132 ] ,
        [ void:class perkonto:PaperStatus ; void:entities   84 ] ,
        [ void:class perkonto:Person      ; void:entities   66 ] ,
        [ void:class perkonto:Conference  ; void:entities   38 ] ,
        [ void:class perkonto:SubmissionID; void:entities   33 ] ,
        [ void:class perkonto:Journal     ; void:entities   22 ] ,
        [ void:class perkonto:PaperBib    ; void:entities    2 ] ;
    void:propertyPartition
        [ void:property perkonto:worksOn      ; void:triples 11337 ] ,
        [ void:property perkonto:receivedBy   ; void:triples  3104 ] ,
        [ void:property perkonto:attends      ; void:triples  2783 ] ,
        [ void:property perkonto:worksWith    ; void:triples  1215 ] ,
        [ void:property perkonto:usedFor      ; void:triples  1206 ] ,
        [ void:property perkonto:partOf       ; void:triples  1006 ] ,
        [ void:property perkonto:sentBy       ; void:triples  1006 ] ,
        [ void:property perkonto:hasAuthor    ; void:triples   637 ] ,
        [ void:property perkonto:inVenue      ; void:triples   353 ] ,
        [ void:property perkonto:evaluates    ; void:triples   305 ] ,
        [ void:property perkonto:movesTo      ; void:triples   199 ] ,
        [ void:property perkonto:uses         ; void:triples   160 ] ,
        [ void:property perkonto:identifies   ; void:triples   157 ] ,
        [ void:property perkonto:hasPaperInfo ; void:triples    27 ] ;
    dcat:landingPage <https://github.com/prantikaC/PERK> ;
    dcat:distribution [ a dcat:Distribution ;
        dcterms:title "PERK KG — Neo4j import CSVs (per-type nodes and relations)"@en ;
        dcat:mediaType "text/csv" ;
        dcterms:format <https://www.iana.org/assignments/media-types/text/csv> ;
        dcat:byteSize "3220316"^^xsd:nonNegativeInteger ;
        dcat:accessURL <https://github.com/prantikaC/PERK/tree/main/datasets/neo4j_import> ] .
